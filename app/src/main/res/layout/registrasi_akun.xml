<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue6"
    android:fillViewport="true"
    android:id="@+id/scrollView">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fillViewport="true">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/background_atas" />

        <TextView
            android:id="@+id/textDaftar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="50dp"
            android:fontFamily="@font/poppinssemibold"
            android:text="Daftar Akun"
            android:textColor="@color/white"
            android:textSize="32sp"/>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="230dp"
            android:layout_height="42dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="100dp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pantau ketinggian air &amp; curah hujan secara real-time di lokasi Anda."
            android:textColor="#A1FFFFFF"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/imageView2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/frame_scroll"
            android:layout_marginTop="200dp"
            tools:layout_editor_absoluteX="0dp">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="40dp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Nama Lengkap"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            android:id="@+id/div_nama"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp">


            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/profile_icon_image"
                android:layout_marginLeft="16dp"
                />

        <EditText
            android:id="@+id/et_nama"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:fontFamily="@font/poppinsmedium"
            android:hint="Masukan Nama Mu"
            android:background="@null"
            android:backgroundTint="@null"
            android:inputType="textPersonName"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            />

        </LinearLayout>

            <TextView
                android:id="@+id/wrongNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textColor="@color/peringatan"
                android:fontFamily="@font/poppins_regular"
                android:text="Masukkan nama anda"
                android:visibility="gone"
                />

        <TextView
            android:id="@+id/textEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Email" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/div_email"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/email_icon"
                android:layout_marginStart="16dp"/>

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@null"
                android:backgroundTint="@null"
                android:fontFamily="@font/poppinsmedium"
                android:hint="Masukkan Email Mu"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

        </LinearLayout>

            <TextView
                android:id="@+id/wrongEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textColor="@color/peringatan"
                android:fontFamily="@font/poppins_regular"
                android:text="Masukkan email anda"
                android:visibility="gone"

                />

        <TextView
            android:id="@+id/textPass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Kata Sandi" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layout_password"
            android:gravity="center"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/password_icon"
                android:layout_marginStart="16dp"
                />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsmedium"
            app:endIconMode="password_toggle"
            app:boxBackgroundMode="none"
            android:background="@null"
            android:backgroundTint="@null"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"

                android:hint="Masukkan Sandi"
                android:inputType="textPassword"
                android:textColor="@color/black"
                />

        </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

            <TextView
                android:id="@+id/wrongPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textColor="@color/peringatan"
                android:fontFamily="@font/poppins_regular"
                android:text="Masukkan sandi anda"
                android:visibility="gone"

                />

        <TextView
            android:id="@+id/textPassConf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsmedium"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:text="Konfirmasi Kata Sandi" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layout_password_conf"
            android:gravity="center"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/password_icon"
            android:layout_marginStart="16dp"
            />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsmedium"
            app:endIconMode="password_toggle"
            app:boxBackgroundMode="none"
            android:background="@null"
            android:backgroundTint="@null"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_passwordConfirm"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:hint="Masukkan Konfirmasi "
                android:inputType="textPassword"
                android:textColor="@color/black"
                />

        </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

            <TextView
                android:id="@+id/wrongPassConf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textColor="@color/peringatan"
                android:fontFamily="@font/poppins_regular"
                android:text="Masukkan sandi konfirmasi anda"
                android:visibility="gone"

                />

        <TextView
            android:id="@+id/pilih_kendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Kendaraan mu"/>

        <ImageView
            android:id="@+id/btn_pilih_kendaraan"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="24dp"
            android:src="@drawable/motor_terpilih" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nomor Plat Kendaraan"
                android:fontFamily="@font/poppinsmedium"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"/>

            <!-- BOX PLAT -->
            <LinearLayout
                android:id="@+id/layoutPlat"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_plat_normal">

                <!-- ICON -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/plat_icon"/>

                <!-- INPUT -->
                <EditText
                    android:id="@+id/et_plat_kendaraan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:background="@android:color/transparent"
                    android:hint="Contoh: DA 1234 XYZ"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#B0B0B0"
                    android:textSize="14sp"
                    android:maxLength="10"
                    android:inputType="textCapCharacters"
                    android:fontFamily="sans-serif-medium"/>

                <!-- STATUS -->
                <ImageView
                    android:id="@+id/imgStatusPlat"
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:src="@drawable/tentang_icon"/>
            </LinearLayout>

            <!-- INFO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- LEFT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginHorizontal="24dp">

                    <ImageView
                        android:id="@+id/imgInfoPlat"
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:src="@drawable/tentang_icon"/>

                    <TextView
                        android:id="@+id/tvInfoPlat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Format: 2 huruf - 4 angka - 3 huruf"
                        android:textColor="@color/blue6"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- COUNTER -->
                <TextView
                    android:id="@+id/tvCounterPlat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/9"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:layout_marginRight="30dp"/>
            </LinearLayout>

        <TextView
            android:id="@+id/textJenisKendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Jenis Motor mu" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrapper_spinner_1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="24dp"
            android:fontFamily="@font/poppinsmedium">

            <com.example.skripsi.CustomSpinner
                android:id="@+id/spinner_motor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:fontFamily="@font/poppinsmedium"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/white"
                android:textSize="14sp"
                />

            <ImageView
                android:id="@+id/iv_arrow_motor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:rotation="-90"
                android:src="@drawable/ic_arrow_down_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/wrongJenis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textColor="@color/peringatan"
                android:fontFamily="@font/poppins_regular"
                android:text="Masukkan jenis motor anda"
                android:visibility="gone"

                />

        <TextView
            android:id="@+id/textModelKendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Model Motor mu" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrapper_spinner_2"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@+id/textModelKendaraan">

            <com.example.skripsi.CustomSpinner
                android:id="@+id/spinner_model_motor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/white"
                android:textSize="14sp"
                />

            <ImageView
                android:id="@+id/iv_arrow_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:rotation="-90"
                android:src="@drawable/ic_arrow_down_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/wrongModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:textSize="16sp"
                android:textColor="@color/peringatan"
                android:fontFamily="@font/poppins_regular"
                android:text="Masukkan model motor anda"
                android:visibility="gone"

                />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_daftar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="120dp"
            android:backgroundTint="@color/blue6"
            android:text="Daftar Sekarang"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
        </LinearLayout>
    </FrameLayout>


</ScrollView>