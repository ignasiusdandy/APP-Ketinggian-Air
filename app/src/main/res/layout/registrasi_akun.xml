<!--            android:hint="********"-->
<!--            android:inputType="textPassword"-->
<!--            android:paddingStart="60dp"-->
<!--            android:paddingEnd="16dp"-->
<!--            android:textColor="@color/black"-->
<!--            android:textSize="16sp"-->
<!--            app:layout_constraintEnd_toEndOf="parent"-->
<!--            app:layout_constraintTop_toBottomOf="@+id/textPassConf" />-->

        <TextView
            android:id="@+id/pilih_kendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Kendaraan mu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_konfirpassword"
            />

        <ImageView
            android:id="@+id/btn_pilih_kendaraan"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/motor_terpilih"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/pilih_kendaraan" />

        <TextView
            android:id="@+id/textJenisKendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Jenis Motor mu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_pilih_kendaraan" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrapper_spinner_1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/poppinsmedium"
            app:layout_constraintTop_toBottomOf="@+id/textJenisKendaraan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.example.skripsi.CustomSpinner
                android:id="@+id/spinner_motor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:fontFamily="@font/poppinsmedium"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/white"/>

            <ImageView
                android:id="@+id/iv_arrow_motor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:rotation="-90"
                android:src="@drawable/ic_arrow_down_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/textModelKendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Model Motor mu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/wrapper_spinner_1" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrapper_spinner_2"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@+id/textModelKendaraan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.example.skripsi.CustomSpinner
                android:id="@+id/spinner_model_motor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/white"/>

            <ImageView
                android:id="@+id/iv_arrow_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:rotation="-90"
                android:src="@drawable/ic_arrow_down_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_daftar"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="70dp"
            android:layout_marginRight="16dp"
            android:backgroundTint="@color/blue6"
            android:text="Masuk Sekarang"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/wrapper_spinner_2" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>