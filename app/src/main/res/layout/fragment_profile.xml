<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".ProfileFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:paddingTop="24dp">

                <!-- BACKGROUND TOP -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/bg_profile_header"/>

                <!-- TITLE -->
                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="Profile"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:fontFamily="@font/poppinssemibold"/>

                <!-- DECOR -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="80dp"
                    android:layout_marginTop="90dp"
                    android:background="@drawable/bg_dot_blue_soft"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="90dp"
                    android:layout_marginTop="130dp"
                    android:background="@drawable/bg_dot_pink_soft"/>

                <!-- AVATAR CONTAINER -->
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="70dp"
                    android:background="@drawable/bg_profile_avatar"
                    android:elevation="6dp"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/profilebiru"/>

                </LinearLayout>

            </RelativeLayout>

            <!-- INFORMASI AKUN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card_profile"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informasi Akun"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppinssemibold"/>

                <!-- NAMA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Nama"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppinsmedium"/>

                <!-- INPUT NAMA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_profile"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <!-- ICON BG -->
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_blue_soft"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/profile_biru_icon"/>

                    </LinearLayout>

                    <!-- TEXT -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Ignasius Dandy"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppinsmedium"/>

                </LinearLayout>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Email"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppinsmedium"/>

                <!-- INPUT EMAIL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_profile"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <!-- ICON BG -->
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_icon_blue_soft"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/email_biru_icon"/>

                    </LinearLayout>

                    <!-- TEXT -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="ignasiusdandy123@gmail.com"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppinsmedium"/>

                </LinearLayout>

            </LinearLayout>

            <!-- MENU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card_profile"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menu"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppinssemibold"/>

                <!-- DAFTAR KENDARAAN -->
                <LinearLayout
                    android:id="@+id/kendaraanUser"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- ICON BG -->
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_blue_soft"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/mobil_biru_icon"/>

                    </LinearLayout>

                    <!-- TEXT -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Daftar Kendaraan"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppinsmedium"/>

                    <!-- ARROW -->
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"/>

                </LinearLayout>

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="#F1F2F6"/>

                <!-- UBAH PASSWORD -->
                <LinearLayout
                    android:id="@+id/ubah_kata_sandi"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- ICON BG -->
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_blue_soft"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/katasandi_biru_icon"/>

                    </LinearLayout>

                    <!-- TEXT -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Ubah Kata Sandi"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppinsmedium"/>

                    <!-- ARROW -->
                    <ImageView
                        android:id="@+id/iconExpand"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"/>

                </LinearLayout>

                <!-- PASSWORD EXPAND -->
                <LinearLayout
                    android:id="@+id/layoutPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="8dp">

                    <EditText
                        android:id="@+id/edtPasswordOld"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_profile"
                        android:hint="Kata Sandi Lama"
                        android:paddingHorizontal="16dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"/>

                    <EditText
                        android:id="@+id/edtPasswordNew"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_profile"
                        android:hint="Kata Sandi Baru"
                        android:paddingHorizontal="16dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"/>

                    <EditText
                        android:id="@+id/edtPasswordConfirm"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_profile"
                        android:hint="Konfirmasi Kata Sandi"
                        android:paddingHorizontal="16dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"/>

                    <!-- BUTTON -->
                    <LinearLayout
                        android:id="@+id/btnSavePassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_button_blue"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Simpan Kata Sandi"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppinssemibold"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="#F1F2F6"/>

                <!-- LOGOUT -->
                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- ICON BG -->
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_red_soft"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/logoutmerah"/>

                    </LinearLayout>

                    <!-- TEXT -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Keluar"
                        android:textColor="#FF5B5B"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppinsmedium"/>

                    <!-- ARROW -->
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_right"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>