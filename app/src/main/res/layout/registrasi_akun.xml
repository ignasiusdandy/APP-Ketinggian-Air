<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue6"
    android:fillViewport="true"
>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/background_atas" />

        <TextView
            android:id="@+id/textDaftar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="50dp"
            android:fontFamily="@font/poppinssemibold"
            android:text="Daftar Akun"
            android:textColor="@color/white"
            android:textSize="32sp"/>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="230dp"
            android:layout_height="42dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="100dp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pantau ketinggian air &amp; curah hujan secara real-time di lokasi Anda."
            android:textColor="#A1FFFFFF"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/imageView2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/frame_scroll"
            android:layout_marginTop="200dp"
            tools:layout_editor_absoluteX="0dp">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Nama Lengkap"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            android:id="@+id/div_nama"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="8dp">


            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/profile_icon_image"
                android:layout_marginLeft="16dp"
                />

        <EditText
            android:id="@+id/et_nama"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:fontFamily="@font/poppinsmedium"
            android:hint="Masukan Nama Mu"
            android:background="@null"
            android:backgroundTint="@null"
            android:inputType="textPersonName"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            />

        </LinearLayout>

        <TextView
            android:id="@+id/textEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Email" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/div_email"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/email_icon"
                android:layout_marginStart="16dp"/>

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@null"
                android:backgroundTint="@null"
                android:fontFamily="@font/poppinsmedium"
                android:hint="Masukkan Email Mu"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:textColor="@color/black"
                android:textSize="16sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/textPass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Kata Sandi" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layout_password"
            android:gravity="center"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/password_icon"
                android:layout_marginStart="16dp"
                />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsmedium"
            app:endIconMode="password_toggle"
            app:boxBackgroundMode="none"
            android:background="@null"
            android:backgroundTint="@null"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:hint="Masukkan Sandi"
                android:inputType="textPassword"
                android:textColor="@color/black"
                />

        </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textPassConf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsmedium"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:text="Konfirmasi Kata Sandi" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layout_password_conf"
            android:gravity="center"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/password_icon"
            android:layout_marginStart="16dp"
            />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsmedium"
            app:endIconMode="password_toggle"
            app:boxBackgroundMode="none"
            android:background="@null"
            android:backgroundTint="@null"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_passwordConfirm"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:hint="Masukkan Konfirmasi "
                android:inputType="textPassword"
                android:textColor="@color/black"
                />

        </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/pilih_kendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Kendaraan mu"/>

        <ImageView
            android:id="@+id/btn_pilih_kendaraan"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/motor_terpilih" />

        <TextView
            android:id="@+id/textJenisKendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Jenis Motor mu" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrapper_spinner_1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/poppinsmedium">

            <com.example.skripsi.CustomSpinner
                android:id="@+id/spinner_motor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:fontFamily="@font/poppinsmedium"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/white"/>

            <ImageView
                android:id="@+id/iv_arrow_motor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:rotation="-90"
                android:src="@drawable/ic_arrow_down_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/textModelKendaraan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:textSize="18sp"
            android:fontFamily="@font/poppinsmedium"
            android:text="Pilih Model Motor mu" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrapper_spinner_2"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@+id/textModelKendaraan">

            <com.example.skripsi.CustomSpinner
                android:id="@+id/spinner_model_motor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:background="@drawable/bg_spinner"
                android:spinnerMode="dropdown"
                android:popupBackground="@color/white"/>

            <ImageView
                android:id="@+id/iv_arrow_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:rotation="-90"
                android:src="@drawable/ic_arrow_down_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_daftar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="120dp"
            android:backgroundTint="@color/blue6"
            android:text="Daftar Sekarang"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
        </LinearLayout>
    </FrameLayout>


</ScrollView>