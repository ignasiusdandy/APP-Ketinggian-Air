<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- ========================= -->
    <!-- 🔹 CONTENT ASLI KAMU -->
    <!-- ========================= -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layoutRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_popup">

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tambah Kendaraan"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- JENIS -->
            <AutoCompleteTextView
                android:id="@+id/etJenis"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:textSize="12sp"
                android:hint="Pilih jenis kendaraan"
                android:background="@drawable/bg_outline"
                android:paddingHorizontal="12dp"/>

            <TextView
                android:id="@+id/tvErrorJenis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jenis wajib diisi"
                android:textColor="#F44336"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- MODEL -->
            <AutoCompleteTextView
                android:id="@+id/etModel"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:textSize="12sp"
                android:layout_marginTop="12dp"
                android:hint="Pilih model kendaraan"
                android:background="@drawable/bg_outline"
                android:paddingHorizontal="12dp"/>

            <TextView
                android:id="@+id/tvErrorModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Model wajib diisi"
                android:textColor="#F44336"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- BATAS -->
            <EditText
                android:id="@+id/etBatas"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:textSize="12sp"
                android:hint="Batas kendaraan (cm)"
                android:layout_marginTop="12dp"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_outline"
                android:paddingHorizontal="12dp"/>

            <TextView
                android:id="@+id/tvErrorBatas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Batas wajib diisi"
                android:textColor="#F44336"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- BUTTON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/btnBatal"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Batal"
                    android:textColor="#777"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"/>

                <LinearLayout
                    android:id="@+id/btnSimpan"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_add"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBtnSimpan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Simpan"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ========================= -->
    <!-- 🔥 LOADING OVERLAY -->
    <!-- ========================= -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_popup"
            android:padding="16dp"
            android:elevation="8dp">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memproses..."
                android:textSize="12sp"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

    </FrameLayout>

</FrameLayout>